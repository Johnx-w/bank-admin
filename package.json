{
  "name": "bank-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build-main": "cd electron && npx tsc -p tsconfig.json",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && npm run electron:build-main && electron .\"",
    "electron:build": "npm run electron:build-main && vite build && electron-builder",
    "electron:preview": "npm run electron:build-main && vite build && electron ."
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "tsx": "^4.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
